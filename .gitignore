# 가상환경
.venv/
venv/

# 파이썬 캐시
__pycache__/
*.pyc

# 환경변수 (API 키 등 비밀정보)
.env
.env.local

# 테스트·커버리지 산출물
.pytest_cache/
.coverage
.ruff_cache/

# 수집·가공 데이터 — 코드로 재생성 가능하므로 저장소에 올리지 않는다
# (폴더 구조는 .gitkeep 으로 유지)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# macOS
.DS_Store
